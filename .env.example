# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file to version control.

# Get these from https://my.telegram.org -> API Development Tools
API_ID=
API_HASH=

# Your phone number in international format, e.g. +15551234567
PHONE_NUMBER=

# Where downloaded files should be saved
DOWNLOAD_DIR=/home/YOUR_USERNAME/Downloads/Telegram

# Optional: where the Telethon session file is stored. If left blank,
# it defaults to a "session" file next to downloader.py, which is the
# most reliable option - it won't move even if DOWNLOAD_DIR changes.
# Keep this file private once created - it grants full account access,
# equivalent to a login token.
SESSION_PATH=

# When the nightly download should run (24-hour format, 0-23 / 0-59).
# Used by install-cron.sh to schedule start.sh - change these and
# re-run ./install-cron.sh to update the schedule, instead of hand
# editing `crontab -e` yourself.
DOWNLOAD_HOUR=0
DOWNLOAD_MINUTE=0
